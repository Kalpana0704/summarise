# Environment variables (server/.env)

PORT=5000
CLIENT_URL=http://localhost:5173

# ── AI Provider (pick ONE) ──────────────────────────────────────────
# Set AI_PROVIDER to force a specific one: groq | ollama | gemini | github
# If omitted, the first configured key below is used automatically.

# Option 1: Groq — FREE, fast, recommended (https://console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Option 2: Ollama — 100% free, runs locally (https://ollama.com)
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2

# Option 3: Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Option 4: GitHub Models API (requires Copilot/Models access)
GITHUB_TOKEN=
AI_BASE_URL=https://models.github.ai/inference
AI_MODEL=openai/gpt-4o-mini

# ── Firebase Admin SDK ─────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

RATE_LIMIT_MAX=20
